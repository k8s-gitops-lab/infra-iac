apiVersion: cert-manager.io/v1
kind: Issuer
metadata:
  name: {{ cert_manager_selfsigned_issuer_name }}
  namespace: {{ cert_manager_namespace }}
spec:
  selfSigned: {}
---
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: {{ cert_manager_ca_certificate_name }}
  namespace: {{ cert_manager_namespace }}
spec:
  isCA: true
  commonName: "{{ cert_manager_ca_common_name }}"
  secretName: {{ cert_manager_ca_secret_name }}
  privateKey:
    algorithm: ECDSA
    size: 256
  issuerRef:
    name: {{ cert_manager_selfsigned_issuer_name }}
    kind: Issuer
    group: cert-manager.io
---
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: {{ cert_manager_cluster_issuer_name }}
spec:
  ca:
    secretName: {{ cert_manager_ca_secret_name }}
